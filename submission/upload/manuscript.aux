\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Low-dispersion spectral product.} $\alpha \cdot \text  {PR}$ as a function of $\alpha $ for all conditions. \text  {MEC}{} (blue) clusters near $\alpha \cdot \text  {PR} \approx 1.4$ with low dispersion (CV $= 0.36$). Synthetic systems (orange) show large $\alpha \cdot \text  {PR}$. The intermediate group (green) bridges the regimes.}}{4}{figure.3}\protected@file@percent }
\newlabel{fig:conservation}{{3}{4}{\textbf {Low-dispersion spectral product.} $\alpha \cdot \text {PR}$ as a function of $\alpha $ for all conditions. \mec {} (blue) clusters near $\alpha \cdot \text {PR} \approx 1.4$ with low dispersion (CV $= 0.36$). Synthetic systems (orange) show large $\alpha \cdot \text {PR}$. The intermediate group (green) bridges the regimes}{figure.3}{}}
