\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Empirical collapse pattern.} Participation ratio PR vs spectral decay rate $\alpha $ for all 43 conditions. \text  {MEC}{} recordings (blue) cluster at low $\alpha $ and high PR; synthetic systems (orange) collapse to PR $\approx 1$ at high $\alpha $. The dashed curve shows the geometric-series reference $\text  {PR} = (1+e^{-\alpha })/(1-e^{-\alpha })$ (Eq.~\ref {eq:reference}). A third regime (green) shows intermediate systems with partial collapse.}}{3}{figure.1}\protected@file@percent }
\newlabel{fig:collapse}{{1}{3}{\textbf {Empirical collapse pattern.} Participation ratio PR vs spectral decay rate $\alpha $ for all 43 conditions. \mec {} recordings (blue) cluster at low $\alpha $ and high PR; synthetic systems (orange) collapse to PR $\approx 1$ at high $\alpha $. The dashed curve shows the geometric-series reference $\text {PR} = (1+e^{-\alpha })/(1-e^{-\alpha })$ (Eq.~\ref {eq:reference}). A third regime (green) shows intermediate systems with partial collapse}{figure.1}{}}
\@writefile{toc}{\contentsline {section}{\numberline {VI}Preprocessing-Matched Null Controls}{3}{section*.19}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {II}{\ignorespaces Null-control distances. Mahalanobis distance $D_M$ (Eq.~\ref {eq:mahal}) between MEC and each null ensemble, under naive and Ledoit--Wolf (LW) covariance estimation. All $p < 0.001$ ($n_{\text  {perm}} = 5000$).}}{3}{table.2}\protected@file@percent }
\newlabel{tab:controls}{{II}{3}{Null-control distances. Mahalanobis distance $D_M$ (Eq.~\ref {eq:mahal}) between MEC and each null ensemble, under naive and Ledoit--Wolf (LW) covariance estimation. All $p < 0.001$ ($n_{\text {perm}} = 5000$)}{table.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {T/N-matched shrinkage comparison.} (Left) PR under naive (blue) and Ledoit--Wolf (red) estimation for each MEC recording, ordered by $T/N$. (Right) Spectral decay rate $\alpha $ under both estimators. Shrinkage increases PR by 3.0\% and decreases $\alpha $ by 2.3\%, consistent with mild isotropic regularization. The MEC-vs-null separation persists under shrinkage (Table~\ref {tab:controls}).}}{3}{figure.2}\protected@file@percent }
\newlabel{fig:shrinkage}{{2}{3}{\textbf {T/N-matched shrinkage comparison.} (Left) PR under naive (blue) and Ledoit--Wolf (red) estimation for each MEC recording, ordered by $T/N$. (Right) Spectral decay rate $\alpha $ under both estimators. Shrinkage increases PR by 3.0\% and decreases $\alpha $ by 2.3\%, consistent with mild isotropic regularization. The MEC-vs-null separation persists under shrinkage (Table~\ref {tab:controls})}{figure.2}{}}
